## Error Handling & Security

### Error Handling

Always handle errors explicitly. Never silently fail.

```typescript
// Good: Convert errors to user-friendly responses
export async function getCandidate(req: Request, res: Response, next: NextFunction) {
    try {
        const candidate = await candidateService.findById(parseInt(req.params.id));
        if (!candidate) {
            return res.status(404).json({
                success: false,
                error: { message: 'Candidate not found', code: 'NOT_FOUND' }
            });
        }
        res.json({ success: true, data: candidate });
    } catch (error) {
        next(error);  // Pass to error middleware
    }
}

// Global error middleware
app.use((error: Error, req: Request, res: Response, next: NextFunction) => {
    logger.error('Unhandled error', { error: error.message });
    res.status(500).json({
        success: false,
        error: { message: 'Internal server error', code: 'INTERNAL_ERROR' }
    });
});
```

### Input Validation

Validate **all user inputs** before processing.

```typescript
// Good: Centralized validation
export function validateCandidateData(data: any): CandidateData {
    if (!data.firstName || typeof data.firstName !== 'string') {
        throw new Error('firstName is required and must be a string');
    }
    if (!data.email || !data.email.includes('@')) {
        throw new Error('email is required and must be valid');
    }
    // ... more validations
    return { firstName: data.firstName, email: data.email };
}

// In controller
const validatedData = validateCandidateData(req.body);
const candidate = await candidateService.create(validatedData);
```

### Environment Variables

Never commit sensitive values. Use `.env` for local development and environment variables in production.

```typescript
// Good: Load and validate environment variables at startup
const requiredEnvVars = ['DATABASE_URL', 'PORT', 'NODE_ENV'];
requiredEnvVars.forEach(varName => {
    if (!process.env[varName]) {
        throw new Error(`Missing required environment variable: ${varName}`);
    }
});

const config = {
    databaseUrl: process.env.DATABASE_URL!,
    port: parseInt(process.env.PORT!),
    nodeEnv: process.env.NODE_ENV!
};
```

### Dependency Injection

Avoid global state. Inject dependencies via constructor.

```typescript
// Good: Inject Prisma client
export class CandidateService {
    constructor(private repository: CandidateRepository) {}
    
    async findById(id: number): Promise<Candidate | null> {
        return this.repository.findById(id);
    }
}

// Bad: Global/import-based dependency
export class CandidateService {
    async findById(id: number): Promise<Candidate | null> {
        return prisma.candidate.findUnique({ where: { id } });  // Hard to test
    }
}
```

