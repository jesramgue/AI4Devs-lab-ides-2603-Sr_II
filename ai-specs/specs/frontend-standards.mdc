## Testing Standards

### Component Testing

Test component behavior and user interactions:

```typescript
// CandidateForm.test.tsx
import { render, screen, fireEvent, waitFor } from '@testing-library/react';
import { CandidateForm } from './CandidateForm';

describe('CandidateForm', () => {
    it('should render form fields', () => {
        render(<CandidateForm onSubmit={jest.fn()} />);
        
        expect(screen.getByLabelText('First Name')).toBeInTheDocument();
        expect(screen.getByLabelText('Email')).toBeInTheDocument();
    });
    
    it('should submit form with valid data', async () => {
        const mockSubmit = jest.fn();
        render(<CandidateForm onSubmit={mockSubmit} />);
        
        fireEvent.change(screen.getByLabelText('First Name'), { target: { value: 'John' } });
        fireEvent.change(screen.getByLabelText('Email'), { target: { value: 'john@example.com' } });
        fireEvent.click(screen.getByRole('button', { name: /submit/i }));
        
        await waitFor(() => {
            expect(mockSubmit).toHaveBeenCalledWith(
                expect.objectContaining({ firstName: 'John', email: 'john@example.com' })
            );
        });
    });
});
```

### Service Testing

Test API communication:

```typescript
// candidateService.test.ts
import { candidateService } from './candidateService';
import * as apiClient from './apiClient';

jest.mock('./apiClient');

describe('candidateService', () => {
    it('should create candidate', async () => {
        const mockData = { id: 1, firstName: 'John', email: 'john@example.com' };
        (apiClient.apiClient.post as jest.Mock).mockResolvedValue({
            data: { data: mockData }
        });
        
        const result = await candidateService.create(mockData);
        
        expect(result).toEqual(mockData);
        expect(apiClient.apiClient.post).toHaveBeenCalledWith('/candidates', mockData);
    });
});
```

### Test Coverage

**Target**: >80% coverage of branches, functions, lines, and statements

```bash
npm test -- --coverage
```

