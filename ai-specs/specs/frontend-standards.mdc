## TypeScript Standards

### Strict Mode Required

`tsconfig.json` must have `"strict": true`:

```json
{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
```

### Type Definitions

Always define types explicitly:

```typescript
// Good: Explicit types
interface UserData {
    id: number;
    firstName: string;
    email: string;
}

export const getUserName = (user: UserData): string => {
    return `${user.firstName}`;
};

// Bad: Missing/implicit types
export const getUserName = (user) => {
    return `${user.firstName}`;
};

// Bad: Using `any`
export const getUserName = (user: any): any => {
    return `${user.firstName}`;
};
```

### Type organization

Store types in type definition files:

```typescript
// types/candidate.types.ts
export interface CandidateData {
    id?: number;
    firstName: string;
    lastName: string;
    email: string;
    educations: EducationInput[];
}

export interface EducationInput {
    institution: string;
    degree: string;
    startDate: string;
    endDate?: string;
}

// In components
import { CandidateData, EducationInput } from '../types/candidate.types';

export const CandidateForm: React.FC<{ onSubmit: (data: CandidateData) => void }> = ({ onSubmit }) => {
    // use types
};
```

