## Bootstrap Integration

### Container & Grid System

Use Bootstrap's grid for layout:

```typescript
import { Container, Row, Col } from 'react-bootstrap';

export const Layout: React.FC<{ children: React.ReactNode }> = ({ children }) => (
    <Container className="my-5">
        <Row>
            <Col md={8} className="mx-auto">
                {children}
            </Col>
        </Row>
    </Container>
);
```

### Form Components

Use React Bootstrap Form components:

```typescript
import { Form, Button, Alert } from 'react-bootstrap';

export const CandidateForm: React.FC<{ onSubmit: (data: CandidateData) => void }> = ({ onSubmit }) => {
    const [formData, setFormData] = useState<CandidateData>(initialData);
    const [error, setError] = useState<string | null>(null);
    
    const handleSubmit = async (e: React.FormEvent) => {
        e.preventDefault();
        try {
            await onSubmit(formData);
        } catch (err) {
            setError(err instanceof Error ? err.message : 'Unknown error');
        }
    };
    
    return (
        <>
            {error && <Alert variant="danger">{error}</Alert>}
            <Form onSubmit={handleSubmit}>
                <Form.Group className="mb-3">
                    <Form.Label>First Name</Form.Label>
                    <Form.Control
                        type="text"
                        value={formData.firstName}
                        onChange={(e) => setFormData({ ...formData, firstName: e.target.value })}
                        required
                        aria-label="First name"
                    />
                </Form.Group>
                <Button variant="primary" type="submit">Submit</Button>
            </Form>
        </>
    );
};
```

