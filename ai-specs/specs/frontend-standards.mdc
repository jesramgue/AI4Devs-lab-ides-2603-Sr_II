## Form Handling

### Controlled Components

All form inputs must be controlled:

```typescript
// Good: Controlled form
const [email, setEmail] = useState('');

return (
    <input
        type="email"
        value={email}
        onChange={(e) => setEmail(e.target.value)}
    />
);

// Bad: Uncontrolled component
return (
    <input type="email" defaultValue="test@example.com" />
);
```

### Form Validation

Client-side validation before submission:

```typescript
// types/validation.ts
export interface ValidationErrors {
    [key: string]: string;
}

export const validateCandidateForm = (data: CandidateFormData): ValidationErrors => {
    const errors: ValidationErrors = {};
    
    if (!data.firstName || data.firstName.trim().length === 0) {
        errors.firstName = 'First name is required';
    }
    if (!/^[A-Za-z]+$/.test(data.firstName)) {
        errors.firstName = 'First name must contain only letters';
    }
    if (!data.email || !data.email.includes('@')) {
        errors.email = 'Valid email is required';
    }
    
    return errors;
};

// In component
const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    const errors = validateCandidateForm(formData);
    if (Object.keys(errors).length > 0) {
        setValidationErrors(errors);
        return;
    }
    // Submit valid form
};
```

